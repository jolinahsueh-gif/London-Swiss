<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>London & Switzerland — Aug 20–27, 2026</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --cream: #f7f3ec;
  --cream2: #ede8df;
  --cream3: #e4ddd2;
  --ink: #1c1a16;
  --ink2: #3a3730;
  --muted: #7a7568;
  --muted2: #a8a099;
  --green: #2a4a35;
  --green2: #3d6b4f;
  --green3: #5a9470;
  --green-light: #edf4ef;
  --london: #1e3a5f;
  --swiss: #a01c2e;
  --concert: #7b2d8b;
  --gold: #c9954a;
  --border: rgba(28,26,22,0.1);
  --border2: rgba(28,26,22,0.18);
  --font-display: 'Libre Baskerville', Georgia, serif;
  --font-body: 'DM Sans', system-ui, sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--cream);color:var(--ink);font-family:var(--font-body);font-size:14px;font-weight:300;line-height:1.6;min-height:100vh}

/* ── NAV ── */
#nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(247,243,236,0.94);backdrop-filter:blur(10px);border-bottom:1px solid var(--border);height:50px;display:flex;align-items:center;padding:0 28px;gap:0;transition:box-shadow 0.3s}
#nav.scrolled{box-shadow:0 2px 16px rgba(28,26,22,0.08)}
.nav-logo{font-family:var(--font-display);font-size:15px;color:var(--green);margin-right:auto;letter-spacing:0.3px}
.nav-steps{display:flex;overflow-x:auto;scrollbar-width:none}
.nav-steps::-webkit-scrollbar{display:none}
.nav-step{padding:6px 12px;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--muted);cursor:pointer;white-space:nowrap;border-radius:4px;transition:all 0.15s}
.nav-step:hover{color:var(--ink);background:var(--cream2)}
.nav-step.active{color:var(--green);font-weight:500}

/* ── HERO ── */
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding:0 60px 72px;position:relative;overflow:hidden}
.hero-pattern{position:absolute;inset:0;background-image:repeating-linear-gradient(0deg,transparent,transparent 39px,rgba(42,74,53,0.04) 40px),repeating-linear-gradient(90deg,transparent,transparent 39px,rgba(42,74,53,0.04) 40px);z-index:0}
.hero-content{position:relative;z-index:1;max-width:720px}
.hero-tag{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--green2);margin-bottom:18px;display:flex;align-items:center;gap:10px}
.hero-tag::before{content:'';display:block;width:36px;height:1px;background:var(--green2)}
.hero-title{font-family:var(--font-display);font-size:clamp(52px,7vw,88px);font-weight:400;line-height:0.95;letter-spacing:-1px;margin-bottom:24px}
.hero-title em{font-style:italic;color:var(--green2)}
.hero-meta{display:flex;flex-wrap:wrap;gap:24px;margin-bottom:36px}
.meta-pair{display:flex;flex-direction:column;gap:2px}
.meta-label{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted2)}
.meta-value{font-size:14px;font-weight:400}
.flights-list{display:flex;flex-direction:column;gap:7px;max-width:620px}
.f-row{display:flex;align-items:center;gap:12px;background:rgba(255,255,255,0.6);border:1px solid var(--border);border-radius:8px;padding:9px 14px;backdrop-filter:blur(4px)}
.f-date{font-size:11px;color:var(--muted);min-width:44px}
.f-route{font-family:var(--font-display);font-size:15px;font-weight:400;min-width:100px}
.f-line{flex:1;display:flex;align-items:center;gap:6px}
.f-line::before,.f-line::after{content:'';flex:1;height:1px;background:var(--border2)}
.f-plane{font-size:11px;color:var(--green2)}
.f-info{font-size:11px;color:var(--muted);text-align:right}
.f-badge{font-size:10px;padding:2px 7px;border-radius:20px;font-weight:500;white-space:nowrap}
.concert-badge{background:rgba(123,45,139,0.12);color:var(--concert);border:1px solid rgba(123,45,139,0.25)}
.scroll-cue{position:absolute;bottom:28px;right:60px;z-index:1;display:flex;flex-direction:column;align-items:center;gap:6px}
.scroll-cue span{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--muted2);writing-mode:vertical-rl}
.scroll-bar{width:1px;height:44px;background:linear-gradient(to bottom,var(--green2),transparent);animation:sb 2s ease-in-out infinite}
@keyframes sb{0%,100%{opacity:0.3}50%{opacity:1}}

/* ── SECTIONS ── */
.section{max-width:860px;margin:0 auto;padding:72px 32px}
.section+.section{padding-top:0}

/* ── CITY BANNER ── */
.city-banner{display:flex;align-items:flex-end;justify-content:space-between;gap:20px;padding:36px 0 24px;border-bottom:2px solid var(--border);margin-bottom:28px;position:relative}
.city-ghost{position:absolute;right:0;bottom:0;font-family:var(--font-display);font-size:80px;font-weight:700;opacity:0.04;line-height:1;user-select:none;letter-spacing:-2px}
.city-name{font-family:var(--font-display);font-size:46px;font-weight:400;line-height:1;letter-spacing:-0.5px}
.city-name em{font-style:italic}
.city-sub{font-size:12px;color:var(--muted);margin-top:6px;letter-spacing:0.3px}
.nights-badge .num{font-family:var(--font-display);font-size:34px;font-weight:400;line-height:1}
.nights-badge .lbl{font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);display:block;margin-top:2px}

/* ── DAY ACCORDION ── */
.day-item{border-bottom:1px solid var(--border);opacity:0;transform:translateY(14px);transition:opacity 0.45s,transform 0.45s}
.day-item.visible{opacity:1;transform:translateY(0)}
.day-trigger{display:flex;align-items:center;gap:18px;padding:18px 0;cursor:pointer;user-select:none}
.day-trigger:hover .day-title{color:var(--green2)}
.day-num{width:34px;height:34px;border-radius:50%;border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:13px;color:var(--muted);transition:all 0.2s;flex-shrink:0}
.day-item.open .day-num{border-color:var(--city-color,var(--green2));color:var(--city-color,var(--green2));background:rgba(61,107,79,0.07)}
.day-text{flex:1}
.day-date{font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted2);margin-bottom:3px}
.day-title{font-family:var(--font-display);font-size:20px;font-weight:400;transition:color 0.2s}
.day-chev{width:26px;height:26px;border:1px solid var(--border);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all 0.25s}
.day-item.open .day-chev{transform:rotate(180deg);border-color:var(--city-color,var(--green2));background:rgba(61,107,79,0.07)}
.day-chev svg{width:11px;height:11px;stroke:var(--muted);fill:none;transition:stroke 0.2s}
.day-item.open .day-chev svg{stroke:var(--city-color,var(--green2))}
.day-body{display:grid;grid-template-rows:0fr;transition:grid-template-rows 0.32s ease}
.day-item.open .day-body{grid-template-rows:1fr}
.day-body-inner{overflow:hidden}

/* ── SLOTS ── */
.slots{padding:0 0 24px 52px;display:flex;flex-direction:column}
.slot{display:grid;grid-template-columns:64px 1fr;gap:14px;padding:12px 0;border-left:1px solid var(--border);position:relative}
.slot::before{content:'';position:absolute;left:-4px;top:18px;width:7px;height:7px;border-radius:50%;background:var(--cream);border:1px solid var(--border2)}
.slot:first-child::before{border-color:var(--city-color,var(--green2));background:var(--city-color,var(--green2))}
.slot-time{padding-left:14px;font-size:11px;color:var(--muted2);padding-top:1px;line-height:1.4}
.slot-name{font-size:13.5px;font-weight:400;color:var(--ink);margin-bottom:3px}
.slot-note{font-size:12.5px;color:var(--muted);line-height:1.55;font-weight:300}
.tags{display:flex;flex-wrap:wrap;gap:5px;margin-top:7px}
.tag{font-size:10.5px;padding:2px 9px;border-radius:20px;font-weight:400}
.tag-tip{background:rgba(201,149,74,0.1);color:#8a6520;border:1px solid rgba(201,149,74,0.25)}
.tag-food{background:rgba(42,74,53,0.08);color:var(--green);border:1px solid rgba(42,74,53,0.2)}
.tag-concert{background:rgba(123,45,139,0.1);color:var(--concert);border:1px solid rgba(123,45,139,0.25)}
.tag-transport{background:rgba(30,58,95,0.08);color:var(--london);border:1px solid rgba(30,58,95,0.2)}

/* ── CONCERT CARD ── */
.concert-card{background:linear-gradient(135deg,rgba(123,45,139,0.08),rgba(123,45,139,0.03));border:1px solid rgba(123,45,139,0.25);border-radius:12px;padding:20px 24px;margin:20px 0;position:relative;overflow:hidden}
.concert-card::before{content:'♪';position:absolute;right:20px;top:50%;transform:translateY(-50%);font-size:60px;opacity:0.06;color:var(--concert)}
.concert-label{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--concert);margin-bottom:6px}
.concert-title{font-family:var(--font-display);font-size:22px;font-weight:400;color:var(--ink);margin-bottom:4px}
.concert-detail{font-size:12.5px;color:var(--muted)}

/* ── TIPS ── */
.tip-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:40px 0}
.tip-card{background:white;border:1px solid var(--border);border-radius:10px;padding:18px 20px}
.tip-label{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--green2);margin-bottom:10px;display:flex;align-items:center;gap:8px}
.tip-label::before{content:'';display:block;width:14px;height:1px;background:var(--green2)}
.tip-card ul{list-style:none;display:flex;flex-direction:column;gap:6px}
.tip-card li{font-size:12.5px;color:var(--ink2);line-height:1.5;padding-left:12px;position:relative}
.tip-card li::before{content:'—';position:absolute;left:0;color:var(--muted2)}

/* ── FOOTER ── */
footer{text-align:center;padding:36px 32px 52px;border-top:1px solid var(--border);font-size:10.5px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted2)}
footer span{color:var(--green2)}

/* ── ANIMATIONS ── */
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.hero-tag{animation:fadeUp 0.6s ease 0.2s both}
.hero-title{animation:fadeUp 0.6s ease 0.4s both}
.hero-meta{animation:fadeUp 0.6s ease 0.55s both}
.flights-list{animation:fadeUp 0.6s ease 0.7s both}

@media(max-width:680px){
  .hero{padding:0 20px 60px}
  .hero-title{font-size:44px}
  .section{padding:52px 18px}
  .city-name{font-size:34px}
  .tip-grid{grid-template-columns:1fr}
  #nav{padding:0 14px}
  .slots{padding-left:16px}
  .slot{grid-template-columns:50px 1fr}
}
@media print{
  #nav,.scroll-cue{display:none}
  .day-body{grid-template-rows:1fr!important}
  body{background:white}
}
</style>
</head>
