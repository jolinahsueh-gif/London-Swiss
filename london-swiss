    slots: [
      { time: '6:30 AM', name: 'Leave hotel for Gatwick (LGW)', note: 'Your SWISS flight departs Gatwick (LGW) at 9:25 AM — not Heathrow. Take the Gatwick Express from London Victoria station: 30 minutes, departs every 15 min. Allow 2+ hrs before departure.', tag_transport: 'Gatwick Express from Victoria — 30 min · £22 single · book in advance', tag_tip: 'CRITICAL: this flight is from Gatwick, not Heathrow — different airport' },
      { time: '9:25 AM', name: 'Fly LGW → ZRH · SWISS', note: '1 hour 40 minutes, nonstop. Arrive Zürich ZRH at 12:05 PM. 90 kg CO₂e.', tag_transport: 'SWISS · 1h40m · Nonstop' },
      { time: '12:30 PM', name: 'Arrive Zürich · check in', note: 'ZRH airport to city center: take the train (10 min, every 10 min, CHF 6.80) or tram. Check into your hotel. Get a Zürich Card for the next 2 days: free public transport + museum entry.', tag_tip: 'Zürich Card: 48h CHF 53 — includes free public transit + most museums' },
      { time: 'Afternoon', name: 'Altstadt (Old Town) & Lake Zürich', note: 'Walk across the Bahnhofbrücke to Altstadt — narrow cobbled streets, medieval fountains, the Grossmünster and Fraumünster churches facing each other across the Limmat. Then down to Bürkiplatz on the lake: sit, watch, let Switzerland happen.', tag_food: 'Café Schober in Old Town — legendary hot chocolate since 1874' },
      { time: 'Evening', name: 'Bahnhofstrasse & dinner', note: 'Walk the length of Bahnhofstrasse — one of the world\'s great shopping streets, though window-shopping here is a sport in itself (Chanel, Patek Philippe, Sprüngli for chocolate). Dinner in the old town.', tag_food: 'Fondue at Zürich Chuchi near Rennweg — authentic, reservations recommended' },
