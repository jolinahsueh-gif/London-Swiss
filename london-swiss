function buildDays(containerId, days) {
  const c = document.getElementById(containerId);
  days.forEach((d, i) => {
    const colorVar = d.color || '--green2';
    const el = document.createElement('div');
    el.className = 'day-item';
    el.style.setProperty('--city-color', `var(${colorVar})`);
    el.innerHTML = `
      <div class="day-trigger" onclick="toggle(this.parentElement)">
        <div class="day-num">${i+1}</div>
        <div class="day-text">
          <div class="day-date">${d.date}</div>
          <div class="day-title">${d.title}</div>
        </div>
        <div class="day-chev"><svg viewBox="0 0 12 8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 1l5 5 5-5"/></svg></div>
      </div>
      <div class="day-body"><div class="day-body-inner"><div class="slots">
        ${d.slots.map((s,si) => `
          <div class="slot">
            <div class="slot-time">${s.time}</div>
            <div>
              <div class="slot-name">${s.name}</div>
              <div class="slot-note">${s.note}</div>
              <div class="tags">
                ${s.tag_tip ? `<span class="tag tag-tip">${s.tag_tip}</span>` : ''}
                ${s.tag_food ? `<span class="tag tag-food">${s.tag_food}</span>` : ''}
                ${s.tag_concert ? `<span class="tag tag-concert">${s.tag_concert}</span>` : ''}
                ${s.tag_transport ? `<span class="tag tag-transport">${s.tag_transport}</span>` : ''}
              </div>
            </div>
          </div>`).join('')}
      </div></div></div>`;
    c.appendChild(el);
  });
}

function toggle(el) { el.classList.toggle('open'); }

buildDays('london-days', LONDON_DAYS);
buildDays('swiss-days', SWISS_DAYS);

document.querySelector('#london-days .day-item').classList.add('open');
document.querySelector('#swiss-days .day-item').classList.add('open');

const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });
document.querySelectorAll('.day-item').forEach((el, i) => {
  el.style.transitionDelay = `${(i % 4) * 55}ms`;
  obs.observe(el);
});

const sections = ['hero','london','swiss','tips'];
const steps = document.querySelectorAll('.nav-step');
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => {
  nav.classList.toggle('scrolled', scrollY > 20);
  let cur = 0;
  sections.forEach((id, i) => {
    const el = document.getElementById(id);
    if (el && scrollY >= el.offsetTop - 100) cur = i;
  });
  steps.forEach((s,i) => s.classList.toggle('active', i === cur));
}, { passive: true });

function goTo(id) {
  const el = document.getElementById(id);
  if (el) window.scrollTo({ top: el.offsetTop - 50, behavior: 'smooth' });
}
</script>
